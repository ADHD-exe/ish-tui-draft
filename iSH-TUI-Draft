Suggested implementation:

```sh
#!/bin/sh
set -u

if [ "$#" -lt 2 ]; then
  echo "Usage: apkdoc add <package...>"
  echo "Example: apkdoc add git curl openssh"
  exit 2
fi

cmd="$1"
shift

case "$cmd" in
  add)
    apk add "$@"

    doc_pkgs=""
    for pkg in "$@"; do
      if apk search -q "${pkg}-doc" | grep -qx "${pkg}-doc"; then
        doc_pkgs="$doc_pkgs ${pkg}-doc"
      fi
    done

    if [ -n "$doc_pkgs" ]; then
      echo "Installing docs:$doc_pkgs"
      apk add $doc_pkgs
      command -v mandocdb >/dev/null 2>&1 && mandocdb || true
    else
      echo "No matching -doc packages found."
    fi
    ;;
  *)
    echo "Unsupported command: $cmd"
    echo "Use: apkdoc add <package...>"
    exit 2
    ;;
esac
```

